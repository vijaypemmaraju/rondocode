# Where the singing models load from. See docs/sing-models.md.
# Production: your HuggingFace repo of phoneme.onnx / vec-768.onnx / gen_*.onnx
VITE_SING_MODELS_BASE=https://huggingface.co/YOUR_HF_USER/sing-models/resolve/main
# Local dev against the static model server instead:
# VITE_SING_MODELS_BASE=http://127.0.0.1:8790

# Optional: override the Supertonic TTS host (defaults to the public repo)
# VITE_SUPERTONIC_BASE=https://huggingface.co/Supertone/supertonic-3/resolve/main
